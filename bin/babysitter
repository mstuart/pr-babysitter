#!/usr/bin/env bash
#
# babysitter — CLI to control the PR babysitter agent
#
# Configuration: place a .babysitterrc in your repo root, or
# ~/.config/pr-babysitter/config. Run `babysitter init` to generate one.
#
set -euo pipefail

export PATH="/opt/homebrew/bin:/usr/local/bin:$HOME/.local/bin:$PATH"

# Resolve symlinks so SCRIPT_DIR points to the real location
SOURCE="$0"
while [ -L "$SOURCE" ]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"

# --- Config loading -----------------------------------------------------------

load_config() {
  # 1. Explicit env var
  if [ -n "${BABYSITTER_CONFIG:-}" ] && [ -f "$BABYSITTER_CONFIG" ]; then
    # shellcheck source=/dev/null
    source "$BABYSITTER_CONFIG"
    return 0
  fi

  # 2. Walk up from cwd to find .babysitterrc
  local dir="$PWD"
  while [ "$dir" != "/" ]; do
    if [ -f "$dir/.babysitterrc" ]; then
      # shellcheck source=/dev/null
      source "$dir/.babysitterrc"
      return 0
    fi
    dir=$(dirname "$dir")
  done

  # 3. XDG / home config
  local xdg="${XDG_CONFIG_HOME:-$HOME/.config}"
  if [ -f "$xdg/pr-babysitter/config" ]; then
    # shellcheck source=/dev/null
    source "$xdg/pr-babysitter/config"
    return 0
  fi

  return 1
}

config_loaded=true
load_config || config_loaded=false

# --- Defaults -----------------------------------------------------------------

REPO="${BABYSITTER_REPO:-}"
AUTHOR="${BABYSITTER_AUTHOR:-}"
MAX_ATTEMPTS="${BABYSITTER_MAX_ATTEMPTS:-10}"
MODEL="${BABYSITTER_MODEL:-sonnet}"
INTERVAL="${BABYSITTER_INTERVAL:-300}"
DATA_DIR="${BABYSITTER_DATA_DIR:-$HOME/.local/share/pr-babysitter}"
LOG_FILE="$DATA_DIR/babysitter.log"
LOCK_FILE="$DATA_DIR/babysitter.lock"
BABYSITTER_SCRIPT="${SCRIPT_DIR}/pr-babysitter.sh"

PLIST_LABEL="dev.babysitter.pr-babysitter"
PLIST_PATH="$HOME/Library/LaunchAgents/$PLIST_LABEL.plist"

REPO_OWNER="${REPO%%/*}"
REPO_NAME="${REPO##*/}"

mkdir -p "$DATA_DIR"

# --- Colors -------------------------------------------------------------------

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

# --- Helpers ------------------------------------------------------------------

require_config() {
  if [ "$config_loaded" = false ]; then
    echo -e "${RED}No config found.${NC} Run ${BOLD}babysitter init${NC} to create one."
    exit 1
  fi
  if [ -z "$REPO" ] || [ -z "$AUTHOR" ]; then
    echo -e "${RED}BABYSITTER_REPO and BABYSITTER_AUTHOR are required.${NC}"
    echo "Edit your .babysitterrc or run ${BOLD}babysitter init${NC}."
    exit 1
  fi
}

# --- Commands -----------------------------------------------------------------

usage() {
  cat <<EOF
${BOLD}babysitter${NC} — PR babysitter agent control

${BOLD}USAGE${NC}
  babysitter <command>

${BOLD}COMMANDS${NC}
  ${GREEN}init${NC}         Create a .babysitterrc config in the current directory
  ${GREEN}start${NC}        Load and start the launchd agent
  ${RED}stop${NC}         Unload and stop the launchd agent
  ${BLUE}status${NC}       Show agent status and current PR overview
  ${CYAN}dashboard${NC}    Live-updating dashboard (refreshes every 30s)
  ${YELLOW}run${NC}          Run one babysitter cycle immediately (foreground)
  ${DIM}logs${NC}         Tail the babysitter log
  ${DIM}logs clear${NC}   Clear the log file
  ${DIM}reset${NC}        Remove all babysitter labels from a PR
  ${DIM}reset-all${NC}    Remove all babysitter labels from all open PRs

${BOLD}CONFIG${NC}
  Config is loaded from (first match wins):
    1. \$BABYSITTER_CONFIG (env var pointing to a file)
    2. .babysitterrc (walking up from cwd)
    3. ~/.config/pr-babysitter/config

EOF
}

cmd_init() {
  local target="${1:-.babysitterrc}"

  if [ -f "$target" ]; then
    echo -e "${YELLOW}$target already exists.${NC} Edit it directly or delete it first."
    return 1
  fi

  # Try to detect repo from git remote
  local detected_repo=""
  local detected_author=""
  detected_repo=$(git remote get-url origin 2>/dev/null | sed -E 's#.*github\.com[:/]##; s/\.git$//' || echo "")
  detected_author=$(gh api user --jq '.login' 2>/dev/null || echo "")

  cat > "$target" <<CONF
# PR Babysitter configuration
# Docs: https://github.com/mstuart/pr-babysitter

# Required: GitHub repo in owner/name format
BABYSITTER_REPO="${detected_repo:-owner/repo}"

# Required: GitHub username — only PRs by this author are babysitted
BABYSITTER_AUTHOR="${detected_author:-your-github-username}"

# Max fix attempts per PR before giving up (default: 10)
# BABYSITTER_MAX_ATTEMPTS=10

# Claude model to use (default: sonnet)
# BABYSITTER_MODEL=sonnet

# Interval in seconds for launchd (default: 300 = 5 min)
# BABYSITTER_INTERVAL=300

# Data directory for logs and lock files
# BABYSITTER_DATA_DIR=\$HOME/.local/share/pr-babysitter

# --- Project-specific commands ------------------------------------------------
# Override these if your project doesn't use npm.

# Install dependencies after checkout
# BABYSITTER_INSTALL_CMD="npm ci --prefer-offline --no-audit --no-fund"

# Type checking / build verification
# BABYSITTER_VERIFY_CMD="npm run verify"

# Run tests
# BABYSITTER_TEST_CMD="npm test"

# Lint and auto-fix
# BABYSITTER_LINT_CMD="npm run lint:fix"

# --- Custom prompt ------------------------------------------------------------
# Point to a file containing a custom Claude prompt template.
# The file can use \$REPO, \$NUMBER, \$TITLE, \$ATTEMPT, \$MAX, \$MERGEABLE,
# \$FAILING, \$UNRESOLVED, \$VERIFY_CMD, \$TEST_CMD, \$LINT_CMD via envsubst.
# BABYSITTER_PROMPT_FILE=""

# Extra rules appended to the default prompt (one per line).
# BABYSITTER_EXTRA_RULES="- This is a monorepo with npm workspaces + Turborepo
# - NEVER run 'npm run seed' (destroys all data)"
CONF

  echo -e "${GREEN}Created $target${NC}"
  echo -e "Edit it, then run ${BOLD}babysitter start${NC}."
}

cmd_start() {
  require_config

  if launchctl list "$PLIST_LABEL" &>/dev/null; then
    echo -e "${YELLOW}Already running.${NC} Use 'babysitter stop' first to restart."
    return 0
  fi

  # Generate the launchd plist
  cat > "$PLIST_PATH" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>$PLIST_LABEL</string>
	<key>ProgramArguments</key>
	<array>
		<string>$BABYSITTER_SCRIPT</string>
	</array>
	<key>StartInterval</key>
	<integer>$INTERVAL</integer>
	<key>StandardOutPath</key>
	<string>$DATA_DIR/launchd-stdout.log</string>
	<key>StandardErrorPath</key>
	<string>$DATA_DIR/launchd-stderr.log</string>
	<key>RunAtLoad</key>
	<true/>
	<key>EnvironmentVariables</key>
	<dict>
		<key>PATH</key>
		<string>/opt/homebrew/bin:/usr/local/bin:$HOME/.local/bin:/usr/bin:/bin</string>
		<key>HOME</key>
		<string>$HOME</string>
	</dict>
</dict>
</plist>
PLIST

  launchctl load "$PLIST_PATH"
  echo -e "${GREEN}Started.${NC} Running every $((INTERVAL / 60)) minutes."
  echo -e "Logs: ${DIM}babysitter logs${NC}"
}

cmd_stop() {
  if ! launchctl list "$PLIST_LABEL" &>/dev/null; then
    echo -e "${YELLOW}Not running.${NC}"
    return 0
  fi
  launchctl unload "$PLIST_PATH"
  rm -f "$LOCK_FILE"
  echo -e "${RED}Stopped.${NC}"
}

cmd_run() {
  require_config
  echo -e "${CYAN}Running babysitter cycle...${NC}"
  "$BABYSITTER_SCRIPT"
  echo -e "${GREEN}Done.${NC}"
}

cmd_logs() {
  if [ "${1:-}" = "clear" ]; then
    > "$LOG_FILE"
    echo -e "${GREEN}Log cleared.${NC}"
    return 0
  fi
  if [ ! -f "$LOG_FILE" ]; then
    echo -e "${DIM}No logs yet.${NC}"
    return 0
  fi
  tail -f "$LOG_FILE"
}

cmd_reset() {
  require_config
  local pr_num="${1:-}"
  if [ -z "$pr_num" ]; then
    echo "Usage: babysitter reset <pr-number>"
    return 1
  fi
  labels=$(gh pr view "$pr_num" --repo "$REPO" --json labels --jq '[.labels[].name | select(startswith("babysitter-"))] | .[]' 2>/dev/null)
  if [ -z "$labels" ]; then
    echo -e "${DIM}No babysitter labels on PR #$pr_num${NC}"
    return 0
  fi
  while IFS= read -r label; do
    gh pr edit "$pr_num" --repo "$REPO" --remove-label "$label" 2>/dev/null || true
    echo -e "Removed ${YELLOW}$label${NC} from PR #$pr_num"
  done <<< "$labels"
  echo -e "${GREEN}Reset complete.${NC}"
}

cmd_reset_all() {
  require_config
  prs=$(gh pr list --repo "$REPO" --author "$AUTHOR" --state open --json number,title,labels)
  echo "$prs" | jq -c '.[]' | while read -r pr; do
    number=$(echo "$pr" | jq -r '.number')
    title=$(echo "$pr" | jq -r '.title')
    labels=$(echo "$pr" | jq -r '[.labels[]?.name // empty | select(startswith("babysitter-"))] | .[]')
    if [ -n "$labels" ]; then
      while IFS= read -r label; do
        gh pr edit "$number" --repo "$REPO" --remove-label "$label" 2>/dev/null || true
      done <<< "$labels"
      echo -e "Reset PR #$number ($title)"
    fi
  done
  echo -e "${GREEN}All babysitter labels cleared.${NC}"
}

pr_status_line() {
  local number="$1" title="$2" mergeable="$3" failing="$4" unresolved="$5" attempt="$6"

  if [ "$mergeable" = "MERGEABLE" ] && [ "$failing" -eq 0 ] && [ "$unresolved" -eq 0 ]; then
    icon="${GREEN}OK${NC}"
  else
    icon="${RED}!!${NC}"
  fi

  if [ "$attempt" -gt 0 ]; then
    attempt_str="${DIM}[attempt $attempt/$MAX_ATTEMPTS]${NC}"
  else
    attempt_str=""
  fi

  issues=""
  [ "$mergeable" != "MERGEABLE" ] && issues="${issues} ${RED}conflict${NC}"
  [ "$failing" -gt 0 ] && issues="${issues} ${RED}${failing} failing${NC}"
  [ "$unresolved" -gt 0 ] && issues="${issues} ${YELLOW}${unresolved} unresolved${NC}"
  [ -z "$issues" ] && issues=" ${GREEN}clean${NC}"

  printf "  %b  ${BOLD}#%-4s${NC} %-50s %b %b\n" "$icon" "$number" "${title:0:50}" "$issues" "$attempt_str"
}

cmd_status() {
  require_config

  echo -e "\n${BOLD}PR Babysitter${NC}"
  echo -e "${DIM}─────────────────────────────────────────────────────────────────────${NC}"
  echo -e "  Repo:     ${BOLD}$REPO${NC}"

  if launchctl list "$PLIST_LABEL" &>/dev/null; then
    echo -e "  Agent:    ${GREEN}running${NC} (every $((INTERVAL / 60)) min)"
  else
    echo -e "  Agent:    ${RED}stopped${NC}"
  fi

  if [ -f "$LOCK_FILE" ]; then
    pid=$(cat "$LOCK_FILE" 2>/dev/null || echo "")
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
      echo -e "  Cycle:    ${CYAN}in progress${NC} (pid $pid)"
    else
      echo -e "  Cycle:    ${DIM}idle${NC}"
    fi
  else
    echo -e "  Cycle:    ${DIM}idle${NC}"
  fi

  if [ -f "$LOG_FILE" ]; then
    last_run=$(grep "^\\[" "$LOG_FILE" 2>/dev/null | tail -1 | sed 's/\[//' | sed 's/\].*//' || true)
    [ -n "$last_run" ] && echo -e "  Last log: ${DIM}$last_run${NC}"
  fi

  echo ""
  echo -e "${BOLD}Open PRs${NC} (by $AUTHOR)"
  echo -e "${DIM}─────────────────────────────────────────────────────────────────────${NC}"

  prs=$(gh pr list --repo "$REPO" --author "$AUTHOR" --state open \
    --json number,title,headRefName,labels 2>/dev/null) || {
    echo -e "  ${RED}Failed to fetch PRs${NC}"
    return 1
  }

  count=$(echo "$prs" | jq 'length')
  if [ "$count" -eq 0 ]; then
    echo -e "  ${DIM}No open PRs${NC}"
    echo ""
    return 0
  fi

  # Subshell pipeline — use `|| true` to prevent pipefail from killing set -e
  echo "$prs" | jq -c '.[]' | while read -r pr; do
    number=$(echo "$pr" | jq -r '.number')
    title=$(echo "$pr" | jq -r '.title')

    gave_up=$(echo "$pr" | jq -r '[.labels[]?.name // empty | select(. == "babysitter-gave-up")] | length')
    if [ "$gave_up" -gt 0 ]; then
      printf "  ${RED}XX${NC}  ${BOLD}#%-4s${NC} %-50s ${RED}gave up${NC}\n" "$number" "${title:0:50}"
      continue
    fi

    attempt=$(echo "$pr" | jq -r '
      [.labels[]?.name // empty
       | select(startswith("babysitter-attempt-"))
       | ltrimstr("babysitter-attempt-")
       | tonumber
      ] | max // 0
    ')

    mergeable=$(gh pr view "$number" --repo "$REPO" --json mergeable --jq '.mergeable' 2>/dev/null || echo "UNKNOWN")
    failing=$(gh pr checks "$number" --repo "$REPO" 2>&1 | grep -cE "^.*\tfail" || true)
    unresolved=$(gh api graphql -f query="
      { repository(owner: \"$REPO_OWNER\", name: \"$REPO_NAME\") {
        pullRequest(number: $number) {
          reviewThreads(first: 50) {
            nodes { isResolved }
          }
        }
      }}" --jq '[.data.repository.pullRequest.reviewThreads.nodes[] | select(.isResolved == false)] | length' 2>/dev/null || echo "0")

    pr_status_line "$number" "$title" "$mergeable" "$failing" "$unresolved" "$attempt"
  done || true

  echo ""
}

render_header() {
  cmd_status 2>&1
  echo -e "${BOLD}Live Log${NC} ${DIM}(streaming — Ctrl+C to exit)${NC}"
  echo -e "${DIM}─────────────────────────────────────────────────────────────────────${NC}"
}

count_header_lines() {
  local term_cols="$1" content="$2" lines=0
  while IFS= read -r line; do
    local stripped
    stripped=$(echo -e "$line" | sed 's/\x1b\[[0-9;]*m//g')
    local len=${#stripped}
    if [ "$len" -eq 0 ]; then
      lines=$((lines + 1))
    else
      lines=$((lines + (len + term_cols - 1) / term_cols))
    fi
  done <<< "$content"
  echo "$lines"
}

cmd_dashboard() {
  require_config

  local term_rows term_cols header header_lines log_start
  term_rows=$(tput lines)
  term_cols=$(tput cols)

  # Initial render
  header=$(render_header)
  header_lines=$(count_header_lines "$term_cols" "$header")
  [ "$header_lines" -gt $((term_rows - 10)) ] && header_lines=$((term_rows - 10))
  log_start=$((header_lines + 1))

  clear
  tput cup 0 0
  echo -e "$header" | head -"$header_lines"

  # Set scroll region below the header
  printf '\033[%d;%dr' "$log_start" "$term_rows"
  tput cup "$log_start" 0

  # Background: refresh header every 30s
  (
    while true; do
      sleep 30
      local new_header new_lines
      new_header=$(render_header 2>/dev/null)
      new_lines=$(count_header_lines "$term_cols" "$new_header")
      [ "$new_lines" -gt $((term_rows - 10)) ] && new_lines=$((term_rows - 10))

      # Save cursor, redraw header, restore cursor
      printf '\033[s'          # save cursor
      printf '\033[r'          # reset scroll region temporarily
      tput cup 0 0             # move to top
      # Clear header area
      for ((i=0; i<header_lines; i++)); do
        printf '\033[2K\n'     # clear each line
      done
      tput cup 0 0             # back to top
      echo -e "$new_header" | head -"$new_lines"

      header_lines=$new_lines
      log_start=$((header_lines + 1))
      printf '\033[%d;%dr' "$log_start" "$term_rows"  # restore scroll region
      printf '\033[u'          # restore cursor
    done
  ) &
  local refresh_pid=$!

  # Clean up on exit
  trap 'kill '"$refresh_pid"' 2>/dev/null; printf "\033[r"; tput cup "$term_rows" 0; echo' EXIT INT TERM

  # Stream logs in the scroll region
  touch "$LOG_FILE"
  tail -f "$LOG_FILE" | while IFS= read -r line; do
    echo -e "  ${DIM}$line${NC}"
  done
}

# --- Route commands -----------------------------------------------------------

case "${1:-}" in
  init)      cmd_init "${2:-}" ;;
  start)     cmd_start ;;
  stop)      cmd_stop ;;
  status)    cmd_status ;;
  dashboard) cmd_dashboard "${2:-30}" ;;
  run)       cmd_run ;;
  logs)      cmd_logs "${2:-}" ;;
  reset)     cmd_reset "${2:-}" ;;
  reset-all) cmd_reset_all ;;
  *)         usage ;;
esac
